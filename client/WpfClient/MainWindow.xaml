<Window x:Class="CJVoiceClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CJ Voice - WiFi麦克风客户端"
        Width="520"
        Height="620"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Window.DataContext>
        <x:Reference>self</x:Reference>
    </Window.DataContext>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />  <!-- 标题 -->
            <RowDefinition Height="auto" />  <!-- IP输入 -->
            <RowDefinition Height="auto" />  <!-- 状态 -->
            <RowDefinition Height="auto" />  <!-- 信息 -->
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Margin="0,8,0,8">
            <TextBlock Text="CJ Voice" Style="{StaticResource TitleText}" />
            <TextBlock Text="WiFi 麦克风客户端 — 接收 Android 端音频并在本机播放" 
                       FontSize="13" 
                       Margin="0,4,0,0" 
                       Foreground="{StaticResource TextSecondary}" />
        </StackPanel>

        <!-- IP 连接卡片 -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,8,0,8">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionLabel}" Text="Android 服务器地址" />
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             x:Name="IpAddressBox"
                             Height="40"
                             FontSize="16"
                             FontFamily="Consolas"
                             Padding="10,0"
                             IsReadOnly="{Binding ElementName=DisconnectButton, Path=IsEnabled}"
                             TextChanged="IpAddressBox_TextChanged"
                             Text="192.168." />
                    <Button Grid.Column="1"
                            x:Name="ConnectButton"
                            Style="{StaticResource PrimaryButton}"
                            Content="&#x25B6; 连接"
                            Height="40"
                            Margin="8,0,0,0"
                            Click="ConnectButton_Click"
                            IsEnabled="False" />
                </Grid>
            </StackPanel>

            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource Card}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ElementName=DisconnectButton, Path=IsEnabled}" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>

        <!-- 状态卡片 -->
        <Border Grid.Row="2" x:Name="StatusCard" Style="{StaticResource Card}" Margin="0,8,0,8">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionLabel}" Text="连接状态" />
                <TextBlock x:Name="StatusText" Style="{StaticResource ValueText}" Text="未连接" />
                <TextBlock x:Name="ClientInfoText" Margin="0,4,0,0" FontSize="13" Foreground="{StaticResource TextSecondary}" />
            </StackPanel>
        </Border>

        <!-- 信息卡片 -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,8,0,8" Padding="12">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionLabel}" Text="音频参数 / 状态" />

                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource SectionLabel}" Text="采样率" />
                        <TextBlock Style="{StaticResource ValueText}" FontSize="14">16 kHz</TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Style="{StaticResource SectionLabel}" Text="位深" />
                        <TextBlock Style="{StaticResource ValueText}" FontSize="14">16-bit</TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Grid.Row="0">
                        <TextBlock Style="{StaticResource SectionLabel}" Text="声道" />
                        <TextBlock Style="{StaticResource ValueText}" FontSize="14">单声道</TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Column="3" Grid.Row="0">
                        <TextBlock Style="{StaticResource SectionLabel}" Text="编码" />
                        <TextBlock Style="{StaticResource ValueText}" FontSize="14">PCM</TextBlock>
                    </StackPanel>
                </Grid>

                <Separator Margin="0,8" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource SectionLabel}" Text="接收流量: " />
                    <TextBlock Grid.Column="1" x:Name="TrafficText" Style="{StaticResource ValueText}" FontFamily="Consolas" FontSize="14" Text="0 KB/s" />
                    <TextBlock Grid.Column="2" x:Name="TotalText" Style="{StaticResource ValueText}" FontFamily="Consolas" FontSize="14" Foreground="{StaticResource TextSecondary}" Text="总计: 0 KB" />
                </Grid>
                <Grid Margin="0,4,0,0">
                    <TextBlock Style="{StaticResource SectionLabel}" Text="输出设备: "/>
                    <TextBlock x:Name="OutputDeviceText" Style="{StaticResource ValueText}" FontSize="12" Foreground="{StaticResource TextSecondary}">
                    </TextBlock>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 断开按钮 -->
        <Button Grid.Row="5"
                x:Name="DisconnectButton"
                Style="{StaticResource StopButton}"
                Content="&#x25A0; 断开"
                Height="48"
                FontSize="16"
                Click="DisconnectButton_Click"
                IsEnabled="False" />

    </Grid>
</Window>
